{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "types": ["bun"],
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    ".agents/skills/**/*.ts",
    "amadeus-contracts/**/*.ts",
    "dev-scripts/**/*.ts",
    "skills/**/*.ts"
  ]
}
