{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "types": ["bun-types"]
  },
  "include": [
    "packages/framework/core/hooks/*.ts",
    "packages/framework/core/tools/*.ts",
    "packages/framework/harness/*/*.ts",
    "scripts/*.ts"
  ]
}
