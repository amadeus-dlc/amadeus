{
  "name": "amadeus",
  "private": true,
  "license": "(MIT OR Apache-2.0)",
  "scripts": {
    "test": "npm run test:all",
    "test:all": "npm run test:ci:mock",
    "test:ci:mock": "npm run typecheck && npm run lint:check && npm run contracts:check && npm run parity:check && npm run claude-wiring:check && npm run grilling-wiring:check && npm run test:it:all && npm run test:it:engine-e2e && npm run diff:check",
    "typecheck": "tsc --noEmit",
    "lint": "npm run lint:check",
    "lint:report": "bun run lints/check.ts --report",
    "lint:check": "bun run lints/check.ts --check",
    "lint:public-type-file:report": "bun run lints/public-type-file/check.ts --report",
    "lint:public-type-file:check": "bun run lints/public-type-file/check.ts --check",
    "lint:ts-complexity:report": "bun run lints/ts-complexity/check.ts --report",
    "lint:ts-complexity:check": "bun run lints/ts-complexity/check.ts --check",
    "contracts:generate": "bun run dev-scripts/generate-amadeus-contracts.ts",
    "contracts:check": "bun run dev-scripts/check-amadeus-contracts.ts",
    "parity:check": "bun run dev-scripts/parity-check.ts",
    "parity:baseline:generate": "bun run dev-scripts/generate-parity-baseline.ts",
    "claude-wiring:check": "bun run dev-scripts/check-claude-host-wiring.ts",
    "grilling-wiring:check": "bun run dev-scripts/check-grilling-wiring.ts",
    "test:it:all": "npm run test:it:amadeus-templates && npm run test:it:lints && npm run test:it:public-type-file && npm run test:it:ts-complexity && npm run test:it:amadeus-contracts && npm run test:it:aidlc-state && npm run test:it:amadeus-validator && npm run test:it:amadeus-validator-domain && npm run test:it:promote-skill && npm run test:it:claude-host-wiring && npm run test:it:grilling-wiring && npm run test:it:llm-runner-options:real-command && npm run test:it:llm-provider-options:mock-real && npm run test:it:migrate-workspace && npm run test:it:parity",
    "test:it:amadeus-templates": "bun run dev-scripts/evals/amadeus-templates/check.ts",
    "test:it:lints": "bun run lints/eval.ts",
    "test:it:public-type-file": "bun run lints/public-type-file/eval.ts",
    "test:it:ts-complexity": "bun run lints/ts-complexity/eval.ts",
    "test:it:amadeus-contracts": "bun run dev-scripts/evals/amadeus-contracts/check.ts",
    "test:it:amadeus-validator": "bun run dev-scripts/evals/amadeus-validator/check.ts",
    "test:it:amadeus-validator-domain": "bun run dev-scripts/evals/amadeus-validator-domain/check.ts",
    "test:it:promote-skill": "bun run dev-scripts/evals/promote-skill/check.ts",
    "test:it:claude-host-wiring": "bun run dev-scripts/evals/claude-host-wiring/check.ts",
    "test:it:grilling-wiring": "bun run dev-scripts/evals/grilling-wiring/check.ts",
    "test:it:llm-runner-options:real-command": "bun run dev-scripts/evals/llm-templates/runner-options-check.ts",
    "test:it:llm-provider-options:mock-real": "bun run dev-scripts/evals/llm-templates/provider-options-check.ts",
    "validate:workspace": "bun run .agents/skills/amadeus-validator/validator/AmadeusValidator.ts",
    "diff:check": "git diff --check",
    "test:it:aidlc-state": "bun run dev-scripts/evals/aidlc-state/check.ts",
    "test:it:migrate-workspace": "bun run dev-scripts/evals/migrate-workspace/check.ts",
    "test:it:parity": "bun run dev-scripts/evals/parity/check.ts",
    "test:it:engine-e2e": "bun run dev-scripts/evals/engine-e2e/check.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
