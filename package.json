{
  "name": "amadeus",
  "private": true,
  "scripts": {
    "test": "npm run test:all",
    "test:all": "npm run test:templates && npm run test:promote && npm run test:llm:runner-options && npm run test:llm:templates:dry-run && npm run validate:all && npm run diff:check",
    "test:templates": "ruby dev-scripts/evals/amadeus-templates/check.rb",
    "test:promote": "ruby dev-scripts/evals/promote-skill/check.rb",
    "test:llm:runner-options": "bun run dev-scripts/evals/llm-templates/runner-options-check.ts",
    "test:llm:templates:dry-run": "bun run dev-scripts/evals/llm-templates/check.ts --dry-run",
    "eval:llm:ping:command": "bun run dev-scripts/evals/llm-templates/check.ts --mode ping --print-command --keep",
    "eval:llm:ping": "bun run dev-scripts/evals/llm-templates/check.ts --mode ping",
    "eval:llm:steering": "bun run dev-scripts/evals/llm-templates/check.ts --mode steering",
    "eval:llm:intent-init": "bun run dev-scripts/evals/llm-templates/check.ts --mode intent-init",
    "eval:llm:intent-ideation": "bun run dev-scripts/evals/llm-templates/check.ts --mode intent-ideation",
    "eval:llm:intent-inception": "bun run dev-scripts/evals/llm-templates/check.ts --mode intent-inception",
    "eval:llm:templates": "bun run dev-scripts/evals/llm-templates/check.ts --mode all",
    "validate": "ruby .agents/skills/amadeus-intent-validator/validator/IntentValidator.rb .",
    "validate:intents": "for state in .amadeus/intents/*/state.json; do intent_dir=${state%/state.json}; intent=${intent_dir##*/}; ruby .agents/skills/amadeus-intent-validator/validator/IntentValidator.rb . \"$intent\"; done",
    "validate:all": "npm run validate && npm run validate:intents",
    "diff:check": "git diff --check"
  }
}
