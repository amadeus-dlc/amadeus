node_modules/
.claude/settings.local.json
# agmsg codex-driver delivery-mode marker: per-clone runtime state, written
# next to .codex/hooks.json by ~/.agents/skills/agmsg (see #770).
.codex/agmsg-delivery-mode
# Codex active hooks are mutable per-clone runtime state. The tracked
# canonical configuration is .codex/hooks.json.example.
.codex/hooks.json
.env
.DS_Store
._*

# dist/ is generated, COMMITTED, and drift-guarded (see CONTRIBUTING.md).
# The negation defeats any user-global `dist/` ignore that would otherwise
# silently drop the distribution trees from commits.
!/dist/

# Generated AI-DLC artifacts (recreated by workflow runs / doctor)
dist/claude/amadeus-docs/
dist/kiro/amadeus-docs/
dist/codex/amadeus-docs/

# Sample/test projects
dist/claude/todo-app/

# packages/setup's own build output (bun build src/cli.ts -> dist/cli.js).
# Unlike the framework's /dist/ above, this is a per-package publish artifact,
# not drift-guarded, and is rebuilt lazily by tests/lib/setup-lazy-build.ts.
packages/setup/dist/

# Test verbose logs
tests/logs/
coverage/

# Local formal-verification toolchain cache (verified before every run).
/.cache/formal-verif/

# Claude worktrees
.claude/worktrees

# AIDLC runtime state (Construction worktrees + future runtime artefacts).
# Anchored to repo root; distinct from .claude/worktrees above which is
# the framework-development worktree convention.
/.amadeus/
/.amadeus/

# Local scratch — explainers, throwaway HTML, etc. (claude writes explainers here)
tmp/

# Local Claude Code memory (personal project preferences, not checked in)
CLAUDE.local.md

# Amadeus self-development runtime state. The shared method and artifacts under
# amadeus/spaces/** are committed; per-user cursors and machine-local runtime
# state are not.
amadeus/active-space
amadeus/spaces/*/intents/active-intent
amadeus/.amadeus-clone-id
amadeus/.amadeus-sessions/
amadeus/spaces/*/intents/*/runtime-graph.json
amadeus/spaces/*/intents/*/.amadeus-*
# No-intent fallback root: before the first intent is born, hooks write their
# health beats to spaces/<space>/intents/ directly.
amadeus/spaces/*/intents/.amadeus-*

# Local-only — pins shfmt formatting to project style via a local
# auto-format tool. Not committed; contributors who do not use it do not need it.
.editorconfig

# Local-only formatter/linter cache — match at any depth so a cache
# directory anywhere in the repo (root, dist/, tools/, etc.) is ignored.
**/.pi-lens/
.pi-lens/
