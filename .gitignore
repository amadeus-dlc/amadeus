node_modules/
.claude/settings.local.json
.env
.DS_Store
._*

# Generated AI-DLC artifacts (recreated by workflow runs / doctor)
dist/claude/amadeus-docs/
dist/kiro/amadeus-docs/
dist/codex/amadeus-docs/

# Sample/test projects
dist/claude/todo-app/

# Test verbose logs
tests/logs/

# Claude worktrees
.claude/worktrees

# AIDLC runtime state (Construction worktrees + future runtime artefacts).
# Anchored to repo root; distinct from .claude/worktrees above which is
# the framework-development worktree convention.
/.aidlc/
/.amadeus/

# Local scratch — explainers, throwaway HTML, etc. (claude writes explainers here)
tmp/

# Local Claude Code memory (personal project preferences, not checked in)
CLAUDE.local.md

# Amadeus self-development runtime state. The shared method and artifacts under
# amadeus/spaces/** are committed; per-user cursors and machine-local runtime
# state are not.
amadeus/active-space
amadeus/spaces/*/intents/active-intent
amadeus/.amadeus-clone-id
amadeus/.amadeus-sessions/
amadeus/spaces/*/intents/*/runtime-graph.json
amadeus/spaces/*/intents/*/.amadeus-*

# Local-only — pins shfmt formatting to project style via a local
# auto-format tool. Not committed; contributors who do not use it do not need it.
.editorconfig

# Local-only formatter/linter cache — match at any depth so a cache
# directory anywhere in the repo (root, dist/, tools/, etc.) is ignored.
**/.pi-lens/
.pi-lens/
