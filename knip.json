{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "packages/framework/core/tools/*.ts",
    "packages/framework/core/hooks/*.ts",
    "packages/framework/harness/*/manifest.ts",
    "packages/framework/harness/*/emit.ts",
    "scripts/package.ts",
    "tests/fixtures/v05-mr9-sensor-fire/scripts/*.ts"
  ],
  "project": [
    "packages/framework/core/tools/**/*.ts",
    "packages/framework/core/hooks/**/*.ts",
    "packages/framework/harness/**/*.ts",
    "scripts/**/*.ts",
    "tests/fixtures/v05-mr9-sensor-fire/**/*.ts"
  ],
  "ignore": [
    "tests/fixtures/v05-mr9-sensor-fire/{failing-linter,failing-type-check,passing-typescript,slow-command}/sample.ts"
  ],
  "ignoreUnresolved": [
    "./amadeus-lib.ts"
  ]
}
