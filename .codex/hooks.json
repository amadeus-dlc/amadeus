{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun .codex/hooks/amadeus-codex-adapter.ts session-start"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun .codex/hooks/amadeus-codex-adapter.ts mint"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun .codex/hooks/amadeus-codex-adapter.ts audit-and-sensors"
          }
        ],
        "matcher": "apply_patch"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun .codex/hooks/amadeus-codex-adapter.ts state-sync"
          }
        ],
        "matcher": "update_plan"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun .codex/hooks/amadeus-codex-adapter.ts runtime-compile"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun .codex/hooks/amadeus-codex-adapter.ts validate-state"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun .codex/hooks/amadeus-codex-adapter.ts post-compact"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun .codex/hooks/amadeus-codex-adapter.ts log-subagent"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun .codex/hooks/amadeus-codex-adapter.ts stop"
          }
        ]
      }
    ]
  }
}
